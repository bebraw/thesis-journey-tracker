{
  "name": "thesis-journey-tracker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.cjs -i ./src/tailwind-input.css -o ./src/styles.css --minify",
    "predev": "npm run build:css",
    "dev": "wrangler dev",
    "predeploy": "npm run build:css",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply thesis_tracker_db --local",
    "db:migrate:remote": "wrangler d1 migrations apply thesis_tracker_db --remote",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "prettier": "3.8.1",
    "tailwindcss": "3.4.17",
    "typescript": "5.9.2",
    "vitest": "3.2.4",
    "wrangler": "4.76.0"
  },
  "overrides": {
    "undici": "7.24.4",
    "esbuild": "0.27.3"
  }
}
