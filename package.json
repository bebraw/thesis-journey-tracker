{
  "name": "thesis-journey-tracker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "account:create": "node ./scripts/create-auth-user.mjs",
    "auth:create-user": "node ./scripts/create-auth-user.mjs",
    "build:css": "mkdir -p ./.generated && tailwindcss -i ./src/tailwind-input.css -o ./.generated/styles.css --minify",
    "ci:local": "agent-ci run --workflow .github/workflows/ci.yml",
    "ci:local:quiet": "agent-ci run --quiet --workflow .github/workflows/ci.yml",
    "ci:local:all": "agent-ci run --all",
    "ci:local:retry": "agent-ci retry",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "types:generate": "HOME=$PWD wrangler types worker-configuration.d.ts",
    "types:check": "HOME=$PWD wrangler types worker-configuration.d.ts --check",
    "db:migrate": "wrangler d1 migrations apply thesis_tracker_db --local",
    "db:migrate:remote": "wrangler d1 migrations apply thesis_tracker_db --remote",
    "db:insights": "wrangler d1 insights thesis_tracker_db --time-period 1d --sort-by time --limit 10",
    "db:insights:json": "wrangler d1 insights thesis_tracker_db --time-period 1d --sort-by time --limit 10 --json",
    "db:seed:sample": "wrangler d1 execute thesis_tracker_db --local --file scripts/sample-data.sql",
    "e2e:prepare": "HOME=$PWD wrangler d1 migrations apply thesis_tracker_db --local --persist-to .wrangler/state/e2e --env-file tests/e2e/.env.e2e && HOME=$PWD wrangler d1 execute thesis_tracker_db --local --persist-to .wrangler/state/e2e --env-file tests/e2e/.env.e2e --file tests/e2e/reset-data.sql && HOME=$PWD wrangler d1 execute thesis_tracker_db --local --persist-to .wrangler/state/e2e --env-file tests/e2e/.env.e2e --file tests/e2e/mock-data.sql",
    "e2e:dev": "CHOKIDAR_USEPOLLING=1 CHOKIDAR_INTERVAL=200 HOME=$PWD wrangler dev --local --ip 127.0.0.1 --port 8788 --inspector-ip 127.0.0.1 --inspector-port 9230 --log-level error --show-interactive-dev-session=false --persist-to .wrangler/state/e2e --env-file tests/e2e/.env.e2e",
    "e2e:server": "npm run e2e:prepare && npm run e2e:dev",
    "e2e": "playwright test",
    "lighthouse": "node ./scripts/run-lighthouse.mjs",
    "readme:screenshots": "node ./scripts/capture-readme-screenshots.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "quality:gate:fast": "npm run types:generate && npm run typecheck && npm test && npm run test:d1",
    "quality:gate": "npm run ci:local:quiet",
    "test:d1": "vitest run tests/d1-integration.test.ts",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build:css",
    "test": "vitest run"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@redwoodjs/agent-ci": "0.7.0",
    "@tailwindcss/cli": "4.2.2",
    "chrome-launcher": "1.2.1",
    "lighthouse": "13.0.3",
    "prettier": "3.8.1",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "vitest": "4.1.1",
    "wrangler": "4.79.0"
  },
  "overrides": {
    "undici": "7.24.4",
    "esbuild": "0.27.3"
  },
  "dependencies": {
    "htmlisp": "0.90.0"
  }
}
