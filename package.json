{
  "name": "thesis-journey-tracker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "account:create": "node ./scripts/create-auth-user.mjs",
    "auth:create-user": "node ./scripts/create-auth-user.mjs",
    "build:css": "mkdir -p ./.generated && tailwindcss -c tailwind.config.cjs -i ./src/tailwind-input.css -o ./.generated/styles.css --minify",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply thesis_tracker_db --local",
    "db:migrate:remote": "wrangler d1 migrations apply thesis_tracker_db --remote",
    "e2e:prepare": "HOME=$PWD wrangler d1 migrations apply thesis_tracker_db --local --persist-to .wrangler/state/e2e --env-file tests/e2e/.env.e2e && HOME=$PWD wrangler d1 execute thesis_tracker_db --local --persist-to .wrangler/state/e2e --env-file tests/e2e/.env.e2e --file tests/e2e/mock-data.sql",
    "e2e:dev": "HOME=$PWD wrangler dev --local --port 8788 --persist-to .wrangler/state/e2e --env-file tests/e2e/.env.e2e",
    "e2e:server": "npm run e2e:prepare && npm run e2e:dev",
    "e2e": "playwright test",
    "lighthouse": "node ./scripts/run-lighthouse.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "chrome-launcher": "1.2.1",
    "lighthouse": "13.0.3",
    "prettier": "3.8.1",
    "tailwindcss": "3.4.17",
    "typescript": "5.9.2",
    "vitest": "3.2.4",
    "wrangler": "4.76.0"
  },
  "overrides": {
    "undici": "7.24.4",
    "esbuild": "0.27.3"
  },
  "dependencies": {
    "htmlisp": "0.82.1"
  }
}
