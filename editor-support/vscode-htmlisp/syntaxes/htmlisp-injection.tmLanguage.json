{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HTMLisp Template Injection",
  "scopeName": "text.html.htmlisp.injection",
  "injectionSelector": "L:string.quoted.template.js, L:string.quoted.template.jsx, L:string.quoted.template.ts, L:string.quoted.template.tsx",
  "patterns": [
    {
      "begin": "\\G\\s*(?=<[A-Za-z])",
      "end": "(?=$)",
      "patterns": [
        {
          "include": "text.html.htmlisp"
        }
      ]
    }
  ]
}
