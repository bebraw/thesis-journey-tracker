{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "types": ["node"]
  },
  "include": ["worker-configuration.d.ts", "src/**/*.ts", "src/**/*.d.ts", "tests/**/*.ts"]
}
