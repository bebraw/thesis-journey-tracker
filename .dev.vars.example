SESSION_SECRET=change-this-to-a-long-random-secret
# Optional but recommended if you want to save Google Calendar credentials inside the app.
# If omitted, the app falls back to SESSION_SECRET for encrypting stored credentials.
# APP_ENCRYPTION_SECRET=change-this-to-a-different-long-random-secret
# Optional: enable full replacement imports only during deliberate recovery work.
# REPLACE_IMPORT_ENABLED=1
